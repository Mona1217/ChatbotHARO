# ====== FLASK ======
FLASK_ENV=development
PORT=5000
# ====== TWILIO / WHATSAPP ======
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
WHATSAPP_NUMBER=whatsapp:+14155238886   # Sandbox or Business sender
# ====== OPENAI (optional for IA) ======
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# ====== RAG (optional) ======
EMBEDDINGS_PROVIDER=sentence-transformers  # or openai
# ====== REDIS (optional; if empty, memory store will be used) ======
REDIS_URL=

# --- CONEXIÓN BD POSTGRES (modo QA/DB directo) ---
DATABASE_URL=postgresql+psycopg2://casaos:casaos@192.168.196.168:5432/postgres

# OTP por correo (si quieres enviar mails reales)
SMTP_HOST=smtp.tu_proveedor.com
SMTP_PORT=587
SMTP_USER=usuario@tu_dominio
SMTP_PASS=tu_password
SMTP_FROM="Academia <no-reply@tu_dominio>"

# Bypass de OTP SOLO para QA (imprime el código en consola)
QA_BYPASS_OTP=true
PROJECT_NAME=Academia de Conducción Bot
PORT=5000

# === Backend SI (Spring) ===
